@app.route("/profile", methods=["GET", "POST"])
def profile_page():
    account = current_agent_account()
    is_agent = bool(account)
    if not is_agent and not session.get("user_id"):
        return redirect(url_for("login"))

    con = db()
    if is_agent:
        row = con.execute("SELECT * FROM agent_accounts WHERE id=?", (int(account["id"]),)).fetchone()
    else:
        row = con.execute("SELECT * FROM users WHERE id=?", (int(session["user_id"]),)).fetchone()
    if not row:
        con.close()
        session.clear()
        return redirect(url_for("login"))
    profile = dict(row)

    if request.method == "POST":
        username = request.form.get("username", "").strip()
        display_name = request.form.get("display_name", "").strip()
        phone = request.form.get("phone", "").strip()
        email = request.form.get("email", "").strip()
        current_password = request.form.get("current_password", "")
        new_password = request.form.get("new_password", "")
        changing_credentials = username != profile.get("username", "") or bool(new_password)

        if not username:
            flash("اسم المستخدم مطلوب", "danger")
        elif new_password and len(new_password) < 8:
            flash("كلمة المرور الجديدة يجب أن تكون 8 أحرف على الأقل", "danger")
        elif changing_credentials and not check_password_hash(profile["password_hash"], current_password):
            flash("كلمة المرور الحالية غير صحيحة", "danger")
        else:
            conflict_user = con.execute("SELECT id FROM users WHERE username=? AND id<>?", (username, int(profile["id"]) if not is_agent else -1)).fetchone()
            conflict_agent = con.execute("SELECT id FROM agent_accounts WHERE username=? AND id<>?", (username, int(profile["id"]) if is_agent else -1)).fetchone()
            if conflict_user or conflict_agent:
                flash("اسم المستخدم مستخدم مسبقاً", "danger")
            else:
                stamp = datetime.now().isoformat(timespec="seconds")
                if is_agent:
                    fields = ["username=?", "display_name=?", "phone=?", "email=?", "updated_at=?"]
                    values = [username, display_name or username, phone, email, stamp]
                    if new_password:
                        fields.append("password_hash=?")
                        values.append(generate_password_hash(new_password))
                    values.append(int(profile["id"]))
                    con.execute("UPDATE agent_accounts SET %s WHERE id=?" % ",".join(fields), tuple(values))
                    session["agent_username"] = username
                    session["agent_display_name"] = display_name or username
                else:
                    fields = ["username=?", "display_name=?", "phone=?", "email=?", "updated_at=?"]
                    values = [username, display_name or username, phone, email, stamp]
                    if new_password:
                        fields.append("password_hash=?")
                        values.append(generate_password_hash(new_password))
                    values.append(int(profile["id"]))
                    con.execute("UPDATE users SET %s WHERE id=?" % ",".join(fields), tuple(values))
                    session["username"] = username
                    session["display_name"] = display_name or username
                con.commit()
                con.close()
                audit_event("تحديث الملف الشخصي", username, "تم تحديث بيانات الحساب")
                flash("تم حفظ الملف الشخصي", "success")
                return redirect(url_for("profile_page"))

    con.close()
    return render_template("profile.html", profile=profile, is_agent=is_agent, settings=get_settings())


@app.route("/account/password", methods=["POST"])
@login_required
def change_password():
    current = request.form.get("current_password", "")
    new = request.form.get("new_password", "")
    if len(new) < 8:
        flash("كلمة المرور الجديدة يجب أن تكون 8 أحرف على الأقل", "danger")
        return redirect(url_for("dashboard"))
    con = db()
    user = con.execute("SELECT * FROM users WHERE id=?", (session["user_id"],)).fetchone()
    if not user or not check_password_hash(user["password_hash"], current):
        con.close()
        flash("كلمة المرور الحالية غير صحيحة", "danger")
        return redirect(url_for("dashboard"))
    con.execute("UPDATE users SET password_hash=? WHERE id=?", (
        generate_password_hash(new), session["user_id"]
    ))
    con.commit()
    con.close()
    flash("تم تغيير كلمة المرور", "success")
    return redirect(url_for("dashboard"))


def startup_reconcile_once():
    """Run slow network reconciliation after the web listener is available."""
    time.sleep(8)
    try:
        ensure_all_agent_devices()
        apply_agent_wireguard()
        sync_direct_subscriber_routes(force=True)
    except Exception as exc:
        try:
            with (APP_DIR / "sync-debug.log").open("a") as handle:
                handle.write(
                    "%s agent-access-startup-error=%s\n"
                    % (
                        datetime.now().isoformat(timespec="seconds"),
                        exc,
                    )
                )
        except Exception:
            pass

    try:
        apply_transparent_webfig_nginx()
    except Exception as exc:
        try:
            with (APP_DIR / "sync-debug.log").open("a") as handle:
                handle.write(
                    "%s transparent-webfig-startup-error=%s\n"
                    % (
                        datetime.now().isoformat(timespec="seconds"),
                        exc,
                    )
                )
        except Exception:
            pass


if __name__ == "__main__":
    # Database migrations are kept synchronous, but all slow WireGuard,
    # iptables and MikroTik reconciliation runs in the background. This
    # prevents the panel from disappearing for minutes after an update.
    init_db()

    background_jobs = (
        (startup_reconcile_once, "startup-network-reconcile"),
        (runtime_cache_loop, "wireguard-runtime-cache"),
        (ping_cache_loop, "router-ping-cache"),
        (subscriber_sync_loop, "subscriber-live-sync"),
        (wireguard_auto_sync_loop, "wireguard-auto-sync"),
        (router_guard_maintenance_loop, "router-cloud-self-heal"),
    )
    for target, name in background_jobs:
        thread = threading.Thread(target=target, name=name, daemon=True)
        thread.start()

    app.run(host="0.0.0.0", port=1994, threaded=True)
