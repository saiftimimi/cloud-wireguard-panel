def _cap_child_permissions(parent, data):
    out={}
    for field in AGENT_PERMISSION_FIELDS:
        out[field] = 1 if parent.get(field) and data.get(field) else 0
    if parent.get("read_only"):
        out["read_only"] = 1
    return out


