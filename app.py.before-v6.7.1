  /ip/address set [find where interface="wg-cloud" and comment="Cloud WireGuard"] address={address} disabled=no
}}

:if ([:len [/interface/wireguard/peers find where interface="wg-cloud" and comment="Cloud Server"]] = 0) do={{
  /interface/wireguard/peers add interface="wg-cloud" public-key="{server_public}" preshared-key="{psk}" endpoint-address={endpoint} endpoint-port={port} allowed-address={server_ip} persistent-keepalive=25 comment="Cloud Server"
}} else={{
  /interface/wireguard/peers set [find where interface="wg-cloud" and comment="Cloud Server"] public-key="{server_public}" preshared-key="{psk}" endpoint-address={endpoint} endpoint-port={port} allowed-address={server_ip} persistent-keepalive=25 disabled=no
}}

:if ([:len [/user/group find where name="cloud-panel-api"]] = 0) do={{
  /user/group add name="cloud-panel-api" policy=read,write,policy,test,api,reboot,sensitive comment="Cloud WG Panel API"
}} else={{
  /user/group set [find where name="cloud-panel-api"] policy=read,write,policy,test,api,reboot,sensitive comment="Cloud WG Panel API"
}}

:if ([:len [/user find where name="{api_username}"]] = 0) do={{
  /user add name="{api_username}" password="{api_password}" group="cloud-panel-api" comment="Cloud WG Panel API"
}} else={{
  /user set [find where name="{api_username}"] password="{api_password}" group="cloud-panel-api" disabled=no comment="Cloud WG Panel API"
}}

:local apiId [/ip/service find where name="api"]
:if ([:len $apiId] > 0) do={ /ip/service set $apiId port=9494 disabled=no address={server_ip} }
:local winboxId [/ip/service find where name="winbox"]
:if ([:len $winboxId] > 0) do={ /ip/service set $winboxId port={winbox_internal} disabled=no }

:put "Cloud WireGuard and API configuration completed"
:put "WireGuard IP: {address}"
:put "API User: {api_username}"
:put "API Port: 9494"
""".format(
        private=peer["private_key"],
        mtu=settings.get("mtu", "1420"),
        address=peer["tunnel_ip"],
        server_public=server_public,
        psk=peer["preshared_key"],
        endpoint=settings["endpoint"],
        port=settings["port"],
        server_ip=server_ip,
        api_username=api_username,
        api_password=api_password,
