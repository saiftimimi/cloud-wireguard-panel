@app.route("/")
@login_required
def dashboard():
    try:
        import_peers_from_ubuntu()
    except Exception:
        pass
    con = db()
    rows = con.execute("SELECT * FROM peers ORDER BY id DESC").fetchall()
    con.close()
    stats = wireguard_peer_stats()
    total = len(rows)
    online = sum(1 for row in rows if stats.get(row["public_key"], {}).get("online"))
    rx = sum(stats.get(row["public_key"], {}).get("rx", 0) for row in rows)
    tx = sum(stats.get(row["public_key"], {}).get("tx", 0) for row in rows)
    peers = []
    for row in rows[:8]:
        item = dict(row)
        item["wg"] = stats.get(item["public_key"], {
            "handshake_text": "-", "rx": 0, "tx": 0, "online": False
        })
        peers.append(item)
    return render_template(
        "dashboard.html",
        peers=peers,
        total=total,
        online=online,
        offline=total-online,
        rx=rx,
        tx=tx,
        settings=get_settings(),
    )


