def router_overview(peer):
    api = connect_peer_api(peer)
    try:
        identity_rows = api.talk("/system/identity/print")
        resource_rows = api.talk("/system/resource/print")
        interface_rows = api.talk("/interface/print")
        address_rows = api.talk("/ip/address/print")
        service_rows = api.talk("/ip/service/print")
        route_rows = api.talk("/ip/route/print")
        identity = identity_rows[0] if identity_rows else {}
        resource = resource_rows[0] if resource_rows else {}
        interfaces = []
        for item in interface_rows:
            interfaces.append({
                "name": item.get("name", "-"),
                "type": item.get("type", "-"),
                "running": item.get("running", "false") == "true",
                "disabled": item.get("disabled", "false") == "true",
                "mtu": item.get("actual-mtu", item.get("mtu", "-")),
                "mac": item.get("mac-address", "-"),
