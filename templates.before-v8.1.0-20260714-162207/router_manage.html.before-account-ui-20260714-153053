{% extends "base.html" %}
{% set heading = "إدارة الراوتر" %}
{% set subheading = peer.name %}
{% block content %}
<div class="action-row page-actions">
  <a class="btn primary" href="{{ url_for('port_forwards_page') }}">تحويلات المشتركين</a>
</div>

{% if error %}
<section class="panel">
  <div class="alert danger">تعذر الاتصال بالراوتر: {{ error }}</div>
  <a class="btn primary" href="{{ url_for('edit_peer', peer_id=peer.id) }}">تعديل إعدادات API</a>
</section>
{% else %}
<div class="stats-grid">
  <article class="stat purple"><div><span>Identity</span><strong>{{ router.identity }}</strong></div></article>
  <article class="stat blue"><div><span>RouterOS</span><strong>{{ router.version }}</strong></div></article>
  <article class="stat teal"><div><span>Uptime</span><strong>{{ router.uptime }}</strong></div></article>
  <article class="stat orange"><div><span>CPU Load</span><strong>{{ router.cpu_load }}%</strong></div></article>
</div>

<div class="two-cols">
  <section class="panel">
    <div class="panel-head"><div><h2>معلومات النظام</h2><p>{{ router.board }}</p><a class="btn primary" target="_blank" rel="noopener" href="{{ url_for('admin_webfig_transparent', peer_id=peer.id) }}">🌐 فتح WebFig</a></div></div>
    <div class="server-row"><span>Architecture</span><b>{{ router.architecture }}</b></div>
    <div class="server-row"><span>CPU</span><b>{{ router.cpu }} × {{ router.cpu_count }}</b></div>
    <div class="server-row"><span>Memory</span><b>{{ router.free_memory }} free / {{ router.total_memory }}</b></div>
    <div class="server-row"><span>Storage</span><b>{{ router.free_hdd }} free</b></div>
    <div class="server-row"><span>Active Routes</span><b>{{ router.active_routes }}</b></div>
  </section>

  <section class="panel">
    <div class="panel-head"><div><h2>إجراءات الراوتر</h2><p>أوامر مباشرة عبر API</p></div></div>
    <form method="post" action="{{ url_for('router_set_identity', peer_id=peer.id) }}">
      <label>تغيير Identity</label>
      <input name="identity" value="{{ router.identity }}" required>
      <button class="btn primary wide">حفظ اسم الراوتر</button>
    </form>
    <form
      method="post"
      action="{{ url_for('router_auto_provision', peer_id=peer.id) }}"
      onsubmit="return confirm('راح يتم تطبيق إعدادات RADIUS وBYPASS وPPP وHotspot على الراوتر. متأكد؟')"
    >
      <button class="btn success wide">
        ⚙️ تهيئة الراوتر تلقائياً
      </button>
    </form>

    <form method="post" action="{{ url_for('router_reboot', peer_id=peer.id) }}" onsubmit="return confirm('متأكد تريد إعادة تشغيل الراوتر؟')">
      <button class="btn danger wide">إعادة تشغيل الراوتر</button>
    </form>
  </section>
</div>

<section class="panel">
  <div class="panel-head"><div><h2>الواجهات</h2><p>Interfaces</p></div><span class="count-badge">{{ router.interfaces|length }}</span></div>
  <div class="table-wrap">
    <table class="mobile-card-table interfaces-table">
      <thead><tr><th>الاسم</th><th>النوع</th><th>الحالة</th><th>MTU</th><th>MAC</th></tr></thead>
      <tbody>
      {% for item in router.interfaces %}
        <tr>
          <td data-label="الاسم"><b>{{ item.name }}</b></td>
          <td data-label="النوع">{{ item.type }}</td>
          <td data-label="الحالة"><span class="status {{ 'on' if item.running and not item.disabled else 'off' }}">{{ 'Running' if item.running and not item.disabled else 'Stopped' }}</span></td>
          <td data-label="MTU">{{ item.mtu }}</td>
          <td data-label="MAC">{{ item.mac }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<div class="two-cols">
  <section class="panel">
    <div class="panel-head"><div><h2>عناوين IP</h2></div><span class="count-badge">{{ router.addresses|length }}</span></div>
    <div class="table-wrap">
      <table class="mobile-card-table addresses-table">
        <thead><tr><th>العنوان</th><th>الواجهة</th><th>الشبكة</th></tr></thead>
        <tbody>
        {% for item in router.addresses %}
          <tr><td data-label="العنوان">{{ item.address }}</td><td data-label="الواجهة">{{ item.interface }}</td><td data-label="الشبكة">{{ item.network }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <div class="panel-head"><div><h2>خدمات IP</h2><p>تشغيل وإيقاف الخدمات</p></div></div>
    <div class="table-wrap">
      <table class="mobile-card-table services-table">
        <thead><tr><th>الخدمة</th><th>المنفذ</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
        {% for item in router.services %}
          <tr>
            <td data-label="الخدمة"><b>{{ item.name }}</b></td>
            <td data-label="المنفذ">{{ item.port }}</td>
            <td data-label="الحالة"><span class="status {{ 'off' if item.disabled else 'on' }}">{{ 'متوقفة' if item.disabled else 'تعمل' }}</span></td>
            <td data-label="إجراء">
              <form method="post" action="{{ url_for('router_set_service', peer_id=peer.id) }}">
                <input type="hidden" name="service_name" value="{{ item.name }}">
                <input type="hidden" name="action" value="{{ 'enable' if item.disabled else 'disable' }}">
                <button class="btn mini {{ 'success' if item.disabled else 'danger' }}">{{ 'تشغيل' if item.disabled else 'إيقاف' }}</button>
              </form>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>
{% endif %}
{% endblock %}