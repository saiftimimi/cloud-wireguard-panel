                        % ",".join(assignments),
                        tuple(values),
                    )
                    con.execute(
                        "DELETE FROM agent_account_peers WHERE account_id=?",
                        (int(account_id),),
                    )
                    for peer_id in sorted(set(peer_ids)):
                        con.execute(
