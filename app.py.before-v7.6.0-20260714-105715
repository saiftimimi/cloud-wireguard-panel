                "iptables", "-t", "nat", "-A",
                "CLOUD_WG_SNAT",
                "-o", interface, "-d", peer_ip,
                "-p", "tcp", "--dport", internal,
                "-j", "MASQUERADE",
            ],
            "iptables -t nat -A CLOUD_WG_SNAT -o %s -d %s -p tcp --dport %s -j MASQUERADE"
            % (interface, peer_ip, internal),
        )
        apply_and_save(
            [
                "iptables", "-A", "CLOUD_WG_FORWARD",
                "-o", interface, "-d", peer_ip,
