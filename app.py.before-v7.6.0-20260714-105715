@app.route("/port-forwards")
@login_required
def port_forwards_page():
    con = db()
    peers = con.execute(
        """
        SELECT
            p.id,
            p.name,
            p.tunnel_ip,
            p.enabled,
            p.mt_host,
            p.mt_port,
            p.mt_username,
            p.winbox_external,
            p.winbox_internal,
            COUNT(pf.id) AS subscriber_count,
            SUM(
                CASE
                    WHEN pf.enabled=1 AND COALESCE(pf.last_error,'')=''
                    THEN 1 ELSE 0
                END
            ) AS active_forward_count,
            MAX(pf.last_seen_at) AS last_subscriber_seen
        FROM peers p
        LEFT JOIN port_forwards pf
            ON pf.peer_id=p.id
        GROUP BY
            p.id,p.name,p.tunnel_ip,p.enabled,
            p.mt_host,p.mt_port,p.mt_username,
            p.winbox_external,p.winbox_internal
        ORDER BY p.name,p.id
        """
    ).fetchall()
    con.close()

    stats = wireguard_peer_stats()
    router_cards = []

    for peer in peers:
        item = dict(peer)
        peer_row = get_peer_or_404(peer["id"])
        public_key = (
            peer_row["public_key"]
            if peer_row else ""
        )
        wg = stats.get(
            public_key,
            {
                "online": False,
                "handshake_text": "-",
                "rx": 0,
                "tx": 0,
            }
        )

        item["wg_online"] = bool(wg.get("online"))
        item["handshake_text"] = wg.get(
            "handshake_text", "-"
        )
        item["subscriber_count"] = int(
            item.get("subscriber_count") or 0
        )
        item["active_forward_count"] = int(
            item.get("active_forward_count") or 0
        )
        item["api_ready"] = bool(
            item.get("mt_host")
            and item.get("mt_username")
            and int(item.get("mt_port") or 0) == 9494
        )
        router_cards.append(item)

    router_cards.sort(
        key=lambda item: (
            bool(item["wg_online"]),
            item["name"].lower(),
        )
    )
    online_count = sum(
        1 for item in router_cards
        if item["wg_online"]
    )

    return render_template(
        "port_forwards.html",
        router_cards=router_cards,
        online_count=online_count,
        offline_count=len(router_cards) - online_count,
        settings=get_settings(),
    )


