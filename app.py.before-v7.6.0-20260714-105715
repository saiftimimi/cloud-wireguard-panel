            ).start()
            flash("تم حفظ الصلاحيات وتطبيقها مباشرة", "success")
            return redirect(url_for("agent_accounts_page"))
        except sqlite3.IntegrityError:
            flash("اسم المستخدم مستخدم مسبقاً", "danger")
